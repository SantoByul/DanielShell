{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc build active file (WSL)",
            "command": "wsl",
            "args": [
                "gcc",
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build using WSL gcc"
        }
    ],
    "version": "2.0.0"
}